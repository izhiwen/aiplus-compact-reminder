{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compact Policy",
  "type": "object",
  "required": [
    "protocolVersion",
    "schemaVersion",
    "templateVersion",
    "lastUpdated",
    "currentGoal",
    "currentPhase",
    "completedWork",
    "openBlockers",
    "ownerGates",
    "next3Actions",
    "doNotDo",
    "recoveryOrder",
    "manualCompactOnly",
    "allowedOwnerGateStatuses",
    "allowedDecisionStatuses",
    "allowedAgentStatuses",
    "allowedEvidenceConfidence",
    "allowedTaskResultStatuses"
  ],
  "properties": {
    "protocolVersion": { "type": "string", "pattern": "^0\\.1\\.0$" },
    "schemaVersion": { "const": "0.1.0" },
    "templateVersion": { "const": "0.1.0" },
    "lastUpdated": { "type": "string", "minLength": 1 },
    "currentGoal": { "type": "string", "minLength": 1 },
    "currentPhase": {
      "enum": [
        "PASS",
        "FAIL",
        "IN_PROGRESS",
        "NEEDS_VERIFICATION",
        "BLOCKED_OWNER_GATE",
        "BLOCKED_MISSING_FILES",
        "BLOCKED_EXTERNAL_ACCESS",
        "BLOCKED_UNCLEAR_GOAL"
      ]
    },
    "completedWork": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "openBlockers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "ownerGates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status", "description"],
        "properties": {
          "status": { "enum": ["APPROVED", "DENIED", "UNKNOWN_PENDING"] },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "next3Actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "doNotDo": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "recoveryOrder": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "resumeSanityCheck": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "manualCompactOnly": { "const": true },
    "allowedOwnerGateStatuses": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "enum": ["APPROVED", "DENIED", "UNKNOWN_PENDING"] }
    },
    "allowedDecisionStatuses": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "enum": ["DECIDED", "PROVISIONAL", "REVERSED", "NEEDS_VERIFICATION"] }
    },
    "allowedAgentStatuses": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": { "enum": ["pending", "running", "blocked", "done", "abandoned"] }
    },
    "allowedEvidenceConfidence": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": { "enum": ["official", "vendor_blog", "github", "measured", "inferred", "unknown"] }
    },
    "allowedTaskResultStatuses": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "PASS",
          "FAIL",
          "IN_PROGRESS",
          "NEEDS_VERIFICATION",
          "BLOCKED_OWNER_GATE",
          "BLOCKED_MISSING_FILES",
          "BLOCKED_EXTERNAL_ACCESS",
          "BLOCKED_UNCLEAR_GOAL"
        ]
      }
    },
    "redactionPlaceholders": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^<[^<>]+>$" }
    },
    "checkpointPolicy": {
      "type": "object",
      "required": [
        "validationPassRequired",
        "denyOnDeniedOwnerGate",
        "denyOnSensitivePattern",
        "unknownOnPendingOwnerGate"
      ],
      "properties": {
        "validationPassRequired": { "type": "boolean" },
        "denyOnDeniedOwnerGate": { "type": "boolean" },
        "denyOnSensitivePattern": { "type": "boolean" },
        "unknownOnPendingOwnerGate": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
